generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisStatus {
  PENDING
  COMPLETED
}

enum KnowledgeDocType {
  CREATED
  FAVORITED
  COLLABORATED
}

enum TaskType {
  IMAGE
  VIDEO
  TEXT_ANALYZE
}

enum TaskStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarKey String?
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects      Project[]
  knowledgeDocs KnowledgeDoc[]
  tasks         Task[]
  assets        Asset[]
  resourceImages ResourceImage[]
}

model Project {
  id              String         @id @default(cuid())
  ownerId         String
  name            String
  ratio           String
  style           String
  stylePrompt     String         @db.Text
  analysisModel   String
  imageModel      String
  videoModel      String
  generalAnalysis AnalysisStatus @default(PENDING)
  basicAnalysis   AnalysisStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  owner      User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  characters Character[]
  items      Item[]
  scenes     Scene[]
  episodes   StoryboardEpisode[]
  compositionTasks CompositionTask[]
  tasks      Task[]
  resourceImages ResourceImage[]

  @@index([ownerId, createdAt])
}

model Character {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String   @db.Text
  bio         String   @db.Text
  voice       String?
  avatarAssetId String?
  identityAssetId String?
  avatarPrompt String? @db.Text
  /// When true, the user clicked "创建为空白角色" instead of running 分析角色.
  /// Frontend uses this to skip the analyze/blank-create choice screen.
  markedBlank Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  styles  CharacterStyle[]
  avatar  Asset?           @relation("CharacterAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  identity Asset?          @relation("CharacterIdentity", fields: [identityAssetId], references: [id], onDelete: SetNull)
  resourceImages ResourceImage[]

  @@index([projectId])
}

model CharacterStyle {
  id          String   @id @default(cuid())
  characterId String
  name        String
  prompt      String   @default("") @db.Text
  model       String?
  ratio       String?
  assetId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  asset     Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  resourceImages ResourceImage[]

  @@index([characterId])
}

model Item {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String   @default("") @db.Text
  prompt      String   @default("") @db.Text
  model       String?
  ratio       String?
  assetId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  resourceImages ResourceImage[]

  @@index([projectId])
}

model Scene {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String   @default("") @db.Text
  prompt      String   @default("") @db.Text
  model       String?
  ratio       String?
  assetId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  resourceImages ResourceImage[]

  @@index([projectId])
}

model ResourceImage {
  id               String     @id @default(cuid())
  ownerId          String
  projectId        String
  kind             String
  source           String     @default("generated")
  status           TaskStatus @default(SUCCEEDED)
  prompt           String     @default("") @db.Text
  model            String?
  ratio            String?
  error            String?    @db.Text
  assetId          String?
  taskId           String?
  characterId      String?
  characterStyleId String?
  sceneId          String?
  itemId           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset          Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  character      Character?      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterStyle CharacterStyle? @relation(fields: [characterStyleId], references: [id], onDelete: Cascade)
  scene          Scene?          @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  item           Item?           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([ownerId, projectId, createdAt])
  @@index([characterId, createdAt])
  @@index([characterStyleId, createdAt])
  @@index([sceneId, createdAt])
  @@index([itemId, createdAt])
  @@index([taskId])
}

model StoryboardEpisode {
  id        String   @id @default(cuid())
  projectId String
  number    Int
  title     String
  content   String   @db.Text
  analyzed  Boolean  @default(false)
  /// Episode-level summary produced by the storyboard "分析剧集" step.
  summary   String   @default("") @db.Text
  /// Scene breakdown produced by "分析剧集" (likeai's per-episode `scenes`).
  /// Json array of { index, title, content, characters: string[], environment }.
  /// Shots reference a scene by its `index` via Shot.sceneIndex.
  scenesJson Json    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots   Shot[]
  compositionTasks CompositionTask[]

  @@unique([projectId, number])
}

/// A single shot (镜头) inside a storyboard episode. Equivalent to one row in
/// likeai's `storyboards` array. Phase-1 supports the manual mode only;
/// `createType` is kept so future AI-assist generated rows can be told apart.
model Shot {
  id              String   @id @default(cuid())
  episodeId       String
  displayId       Int
  /// 'new' (a fresh shot) | 'continuation' (continues from another shot's last frame)
  shotType        String   @default("new")
  /// preId points at another Shot.displayId in the same episode whose last
  /// frame seeds this shot. Null when shotType = 'new'.
  preId           Int?
  duration        Int      @default(4)
  prompt          String   @default("") @db.Text
  model           String   @default("seedance")
  ratio           String   @default("16:9")
  resolution      String   @default("720p")
  generateAudio   Boolean  @default(false)
  /// 'manual' (user created) | 'assist' (AI-assist batch generated).
  createType      String   @default("manual")
  /// Which episode scene (StoryboardEpisode.scenesJson[].index) this shot belongs to.
  /// Shots are partitioned per scene, matching likeai's /episode/:id/:sceneIndex/storyboards.
  sceneIndex      Int      @default(0)

  sketchAssetId    String?
  sketchTaskId     String?
  videoAssetId     String?
  lastFrameAssetId String?
  videoTaskId      String?

  /// Json arrays of references chosen by the user. We keep them as ID arrays
  /// (rather than join tables) so a shot can survive deletion of a referenced
  /// character/scene without cascading away — we just filter out missing IDs
  /// at read time.
  characterStyleIds Json @default("[]")
  sceneIds          Json @default("[]")
  itemIds           Json @default("[]")
  compositionTaskIds Json @default("[]")
  /// Character/role names produced by AI-assist (likeai's `roles`). Display-only;
  /// resolved to characterStyleIds when a matching styled character exists.
  roleNames         Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  episode    StoryboardEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sketch     Asset?            @relation("ShotSketch", fields: [sketchAssetId], references: [id], onDelete: SetNull)
  sketchTask Task?             @relation("ShotSketchTask", fields: [sketchTaskId], references: [id], onDelete: SetNull)
  video      Asset?            @relation("ShotVideo", fields: [videoAssetId], references: [id], onDelete: SetNull)
  lastFrame  Asset?            @relation("ShotLastFrame", fields: [lastFrameAssetId], references: [id], onDelete: SetNull)
  videoTask  Task?             @relation("ShotVideoTask", fields: [videoTaskId], references: [id], onDelete: SetNull)
  compositionCandidates CompositionCandidate[]

  @@unique([episodeId, displayId])
  @@index([episodeId])
  @@index([episodeId, sceneIndex])
  @@index([sketchTaskId])
}

model KnowledgeDoc {
  id        String           @id @default(cuid())
  ownerId   String
  title     String
  type      KnowledgeDocType
  content   String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, type])
}

model Task {
  id          String     @id @default(cuid())
  ownerId     String
  projectId   String?
  type        TaskType
  status      TaskStatus @default(QUEUED)
  provider    String
  input       Json
  output      Json?
  error       String?
  costCredits Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  owner   User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assets  TaskAsset[]
  shotSketches Shot[]      @relation("ShotSketchTask")
  shots   Shot[]      @relation("ShotVideoTask")
  resourceImages ResourceImage[]
  compositionImageTasks CompositionTask[] @relation("CompositionImageTask")
  compositionGridTasks CompositionTask[]  @relation("CompositionGridTask")
  compositionImageRunJobs CompositionImageRun[] @relation("CompositionImageRunTask")
  compositionGridRunJobs CompositionGridRun[] @relation("CompositionGridRunTask")

  @@index([ownerId, status, createdAt])
  @@index([projectId, type])
}

model Asset {
  id          String   @id @default(cuid())
  ownerId     String
  bucket      String
  key         String
  contentType String
  sizeBytes   Int
  width       Int?
  height      Int?
  durationMs  Int?
  createdAt   DateTime @default(now())

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  characterAvatars Character[]     @relation("CharacterAvatar")
  characterIdentities Character[]  @relation("CharacterIdentity")
  characterStyles CharacterStyle[]
  items           Item[]
  scenes          Scene[]
  taskAssets      TaskAsset[]
  resourceImages  ResourceImage[]
  shotSketches    Shot[]           @relation("ShotSketch")
  shotVideos      Shot[]           @relation("ShotVideo")
  shotLastFrames  Shot[]           @relation("ShotLastFrame")
  compositionTaskImages CompositionTask[] @relation("CompositionTaskImage")
  compositionTaskGrids  CompositionTask[] @relation("CompositionTaskGrid")
  compositionImageRunOutputs CompositionImageRun[] @relation("CompositionImageRunOutput")
  compositionGridRunOutputs  CompositionGridRun[]  @relation("CompositionGridRunOutput")
  compositionCandidates CompositionCandidate[]

  @@unique([bucket, key])
  @@index([ownerId, createdAt])
}

model TaskAsset {
  taskId  String
  assetId String
  role    String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([taskId, assetId, role])
}

/// A generated "合成镜头" task. It bridges analyzed剧情场景 with the
/// existing character / scene素材 / item references, then produces a
/// composited first-frame image and 3x3 storyboard candidates.
model CompositionTask {
  id             String   @id @default(cuid())
  projectId      String
  episodeId      String
  sceneIndex     Int
  title          String
  scriptExcerpt  String   @db.Text
  prompt         String   @default("") @db.Text
  status         String   @default("DRAFT")
  error          String?  @db.Text
  characterStyleIds Json  @default("[]")
  sceneIds       Json     @default("[]")
  itemIds        Json     @default("[]")
  imageAssetId   String?
  imageTaskId    String?
  gridAssetId    String?
  gridTaskId     String?
  currentImageRunId String?
  currentGridRunId  String?
  syncedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode    StoryboardEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  imageAsset Asset?            @relation("CompositionTaskImage", fields: [imageAssetId], references: [id], onDelete: SetNull)
  imageTask  Task?             @relation("CompositionImageTask", fields: [imageTaskId], references: [id], onDelete: SetNull)
  gridAsset  Asset?            @relation("CompositionTaskGrid", fields: [gridAssetId], references: [id], onDelete: SetNull)
  gridTask   Task?             @relation("CompositionGridTask", fields: [gridTaskId], references: [id], onDelete: SetNull)
  currentImageRun CompositionImageRun? @relation("CompositionTaskCurrentImageRun", fields: [currentImageRunId], references: [id], onDelete: SetNull)
  currentGridRun  CompositionGridRun?  @relation("CompositionTaskCurrentGridRun", fields: [currentGridRunId], references: [id], onDelete: SetNull)
  imageRuns CompositionImageRun[] @relation("CompositionTaskImageRuns")
  gridRuns  CompositionGridRun[]  @relation("CompositionTaskGridRuns")
  candidates CompositionCandidate[]

  @@unique([episodeId, sceneIndex])
  @@index([projectId, status, createdAt])
  @@index([imageTaskId])
  @@index([gridTaskId])
  @@index([currentImageRunId])
  @@index([currentGridRunId])
}

model CompositionImageRun {
  id             String   @id @default(cuid())
  taskId         String
  prompt         String   @db.Text
  negativePrompt String  @default("") @db.Text
  model          String
  ratio          String
  quality        String   @default("1080p")
  outputCount    Int      @default(1)
  seed           String?
  characterConsistency Int @default(50)
  sceneConsistency     Int @default(50)
  itemConsistency      Int @default(50)
  params         Json     @default("{}")
  referenceAssetIds Json  @default("[]")
  characterStyleIds Json  @default("[]")
  sceneIds       Json     @default("[]")
  itemIds        Json     @default("[]")
  status         String   @default("QUEUED")
  error          String?  @db.Text
  costCredits    Int      @default(0)
  taskJobId      String?
  outputAssetId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task        CompositionTask @relation("CompositionTaskImageRuns", fields: [taskId], references: [id], onDelete: Cascade)
  taskJob     Task?           @relation("CompositionImageRunTask", fields: [taskJobId], references: [id], onDelete: SetNull)
  outputAsset Asset?          @relation("CompositionImageRunOutput", fields: [outputAssetId], references: [id], onDelete: SetNull)
  gridRuns    CompositionGridRun[]
  currentForTasks CompositionTask[] @relation("CompositionTaskCurrentImageRun")

  @@index([taskId, createdAt])
  @@index([taskJobId])
  @@index([outputAssetId])
}

model CompositionGridRun {
  id             String   @id @default(cuid())
  taskId         String
  imageRunId     String
  model          String
  ratio          String
  specification  String   @default("3x3")
  variationMode  String   @default("auto_angles")
  consistency    Int      @default(80)
  inheritStyle   Boolean  @default(true)
  inheritSeed    Boolean  @default(false)
  params         Json     @default("{}")
  status         String   @default("READY")
  error          String?  @db.Text
  costCredits    Int      @default(0)
  taskJobId      String?
  gridAssetId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task      CompositionTask    @relation("CompositionTaskGridRuns", fields: [taskId], references: [id], onDelete: Cascade)
  imageRun  CompositionImageRun @relation(fields: [imageRunId], references: [id], onDelete: Cascade)
  taskJob   Task?               @relation("CompositionGridRunTask", fields: [taskJobId], references: [id], onDelete: SetNull)
  gridAsset Asset?             @relation("CompositionGridRunOutput", fields: [gridAssetId], references: [id], onDelete: SetNull)
  candidates CompositionCandidate[]
  currentForTasks CompositionTask[] @relation("CompositionTaskCurrentGridRun")

  @@index([taskId, createdAt])
  @@index([imageRunId])
  @@index([taskJobId])
  @@index([gridAssetId])
}

model CompositionCandidate {
  id           String   @id @default(cuid())
  taskId       String
  gridRunId    String?
  gridIndex    Int
  angleLabel   String?
  assetId      String?
  selected     Boolean  @default(false)
  status       String   @default("READY")
  appliedMode  String?
  appliedAt    DateTime?
  syncedShotId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task       CompositionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  gridRun    CompositionGridRun? @relation(fields: [gridRunId], references: [id], onDelete: Cascade)
  asset      Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  syncedShot Shot?           @relation(fields: [syncedShotId], references: [id], onDelete: SetNull)

  @@unique([gridRunId, gridIndex])
  @@index([taskId, selected])
  @@index([gridRunId, selected])
  @@index([syncedShotId])
}
