# Database (host dev — connects to docker postgres on localhost)
DATABASE_URL=postgresql://oneness:oneness@localhost:5432/oneness?schema=public

# Redis (host dev)
REDIS_URL=redis://localhost:6379

# MinIO (host dev — browser AND host services use localhost:9000)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=oneness
MINIO_SECRET_KEY=oneness-secret
MINIO_BUCKET_USER_UPLOADS=user-uploads
MINIO_BUCKET_TASK_OUTPUTS=task-outputs

# API server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated origins allowed to call the API
WEB_ORIGINS=http://localhost:3000

# Shared secret used by future external workflows hitting /api/internal/*
INTERNAL_SECRET=change-me-to-a-long-random-string

# Frontend → API base URL (read by Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Worker provider selection ----------------------------------------------
# Worker picks the concrete provider for each task type from these names.
# Image: stub | openai
# Video: stub | seedance | seedance-fast
# Text:  stub | openai
PROVIDER_IMAGE=stub
PROVIDER_VIDEO=stub
PROVIDER_TEXT=stub

# --- OpenAI / OpenAI-compatible provider ------------------------------------
# Used by PROVIDER_IMAGE=openai and PROVIDER_TEXT=openai. The same env block
# drives api.openai.com OR any OpenAI-compatible proxy (ZenMux, OpenRouter,
# DeepSeek, Moonshot, …). Switch backends by changing OPENAI_BASE_URL and
# the model names — no code change required.
#
# Direct OpenAI:
#   OPENAI_API_KEY=sk-...
#   # leave OPENAI_BASE_URL unset (SDK defaults to https://api.openai.com/v1)
#   OPENAI_TEXT_MODEL=gpt-4o-mini
#   OPENAI_IMAGE_MODEL=gpt-image-1
#
# ZenMux (OpenAI-compatible proxy, models are namespaced as <vendor>/<id>):
#   OPENAI_API_KEY=sk-ai-v1-...        # ZenMux PAYG or subscription key
#   OPENAI_BASE_URL=https://zenmux.ai/api/v1
#   OPENAI_TEXT_MODEL=openai/gpt-4o-mini
#   OPENAI_IMAGE_MODEL=openai/gpt-image-1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional: use a separate OpenAI-compatible endpoint/key for image generation
# while keeping text analysis on OPENAI_BASE_URL / OPENAI_API_KEY.
IMAGE_OPENAI_API_KEY=
IMAGE_OPENAI_BASE_URL=

# --- Volcengine Ark / Doubao Seedance video provider -----------------------
# Used by PROVIDER_VIDEO=seedance and PROVIDER_VIDEO=seedance-fast.
# Get a key at: https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
# Caller picks the model per-task via input.model:
#   doubao-seedance-2-0-260128       (Standard, higher quality)
#   doubao-seedance-2-0-fast-260128  (Fast, cheaper)
ARK_API_KEY=
# Override only when targeting a non-default region/host:
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- Public asset URL for outbound providers --------------------------------
# Seedance (and future url-pull providers) need reference assets at a
# publicly reachable URL. Set this to a host that fronts the same MinIO
# storage and is reachable from the provider's network (direct exposure /
# CDN reverse-proxy / TOS mirror). Leave unset in dev — pure text-to-video
# still works; reference-asset tasks need a tunnel (ngrok / cloudflared)
# or a public mirror.
# MINIO_PUBLIC_ENDPOINT=https://media.example.com
